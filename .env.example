# =============================================================================
# 服装电商运营管理系统 — 环境变量样例
# 把本文件复制到 backend/.env 并填入真实值
# =============================================================================

# ----- 环境标识 -----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ----- Database (PostgreSQL 16) -----
# 应用主连接（启用 RLS 角色）
DATABASE_URL_APP=postgresql+asyncpg://clothing_app:app_password@postgres:5432/clothing_erp
# 系统任务连接（绕过 RLS 角色）
DATABASE_URL_BYPASS=postgresql+asyncpg://clothing_bypass:bypass_password@postgres:5432/clothing_erp
# 同步连接（pg_dump 备份脚本用）
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/clothing_erp
# audit_log 归档专用连接
DATABASE_URL_ARCHIVER=postgresql+asyncpg://clothing_archiver:archiver_password@postgres:5432/clothing_erp

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ----- Redis 7 -----
REDIS_URL_CACHE=redis://redis:6379/0
REDIS_URL_CELERY_BROKER=redis://redis:6379/1
REDIS_URL_CELERY_BACKEND=redis://redis:6379/2

# ----- JWT -----
# 生成方式：openssl rand -hex 32
JWT_SECRET=please-replace-with-256-bit-hex-string-via-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- 凭据加密（U12 启用，U01 占位） -----
# 生成方式：openssl rand -base64 32
CREDENTIAL_MASTER_KEY=please-replace-base64-32-bytes-via-openssl-rand-base64-32

# ----- 密码策略 -----
BCRYPT_ROUNDS=12

# ----- CORS -----
CORS_ALLOWED_ORIGINS=https://app.clothinkai.com,https://staging.app.clothinkai.com,http://localhost:5173

# ----- Cloudflare R2 -----
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=clothing-erp-public
R2_BUCKET_PRIVATE=clothing-erp-private
R2_BUCKET_CREDENTIALS=clothing-erp-credentials
R2_BUCKET_BACKUPS=clothing-erp-backups
R2_PUBLIC_BASE_URL=

# ----- Sentry -----
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- 备份保留策略 -----
BACKUP_RETAIN_DAILY_DAYS=30
BACKUP_RETAIN_MONTHLY_MONTHS=12
AUDIT_RETAIN_MONTHS=12

# ----- 限流 -----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN_IP=20/minute
LOGIN_FAIL_TTL_SECONDS=900
LOGIN_FAIL_LIMIT_PER_IP_USERNAME=5
ACCOUNT_LOCK_THRESHOLD=10

# ----- 缓存 TTL -----
PERM_CACHE_TTL_SECONDS=300

# ----- 初始管理员 -----
INITIAL_ADMIN_USERNAME=admin

# ----- Frontend (Vite 构建时注入) -----
VITE_API_BASE_URL=http://localhost:8000
VITE_SENTRY_DSN=

# ----- 企微集成（U07） -----
# 企微 API 域名（本地/测试可指向 mock 桩）
WECOM_API_BASE=https://qyapi.weixin.qq.com
# 企微外部调用超时（秒）
WECOM_HTTP_TIMEOUT=10
# access_token 缓存 TTL（企微 7200 留余量）
WECOM_TOKEN_TTL=7000
# 催发扫描调度（cron，Asia/Shanghai；celery-beat 服务）
WECOM_URGE_SCAN_CRON=0 9 * * *
